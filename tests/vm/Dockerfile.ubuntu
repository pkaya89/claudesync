FROM ubuntu:24.04
RUN apt-get update && apt-get install -y nodejs npm bash && rm -rf /var/lib/apt/lists/*
RUN useradd -m testuser
COPY . /opt/claudesync
RUN chown -R testuser:testuser /opt/claudesync
USER testuser
WORKDIR /opt/claudesync
RUN npm install --ignore-scripts
CMD ["npm", "test"]
