{
  "name": "@pinana/claudesync",
  "version": "0.1.7",
  "description": "Sync your Claude Code config across machines. Dotfiles for Claude.",
  "type": "module",
  "bin": {
    "claudesync": "./cli/index.js"
  },
  "files": [
    "cli/",
    "setup.sh",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:integration": "node --test tests/integration.test.js",
    "test:vm": "./tests/vm/run-all.sh",
    "test:vm:ubuntu": "./tests/vm/run-single.sh ubuntu",
    "release": "npm publish --access public --auth-type=web"
  },
  "keywords": [
    "claude",
    "claude-code",
    "dotfiles",
    "sync",
    "config"
  ],
  "license": "MIT",
  "author": "Pinar Kaya",
  "repository": {
    "type": "git",
    "url": "https://github.com/pkaya89/claudesync.git"
  },
  "homepage": "https://github.com/pkaya89/claudesync",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0"
  }
}
